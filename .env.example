# Example environment variables for local development.
# Copy this file to `.env` and fill in the real values locally.

# https://www.builder.io/c/docs/using-your-api-key
VITE_PUBLIC_BUILDER_KEY=__BUILDER_PUBLIC_KEY__
PING_MESSAGE="ping pong"

# Cookiebot CMP
# The CBID / Domain Group ID is public by design and will appear in the built HTML.
# Keep only Cookiebot API keys server-side if you use their API separately.
VITE_COOKIEBOT_ENABLED=true
VITE_COOKIEBOT_CBID=e976e26f-410c-49de-be77-268ae03e17d7
VITE_COOKIEBOT_CULTURE=de

# Resend (contact form)
RESEND_API_KEY=
RESEND_FROM_EMAIL="Numerix Kontakt <no-reply@example.com>"
CONTACT_TO_EMAIL=info@example.com

# Frontend API base (Option B). Example: https://your-api-host
VITE_API_BASE_URL=https://your-api-host.example.com

# Admin panel auth (server-side only; keep secret in production)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
ADMIN_SESSION_TTL_MINUTES=480

# Umami Analytics (free)
# 1) Add your website in Umami and copy website id.
# 2) Use cloud script URL or your self-hosted script URL.
VITE_UMAMI_WEBSITE_ID=your-website-id
VITE_UMAMI_SCRIPT_URL=https://cloud.umami.is/script.js
VITE_UMAMI_HOST_URL=
VITE_UMAMI_DOMAINS=

# Optional: links shown inside /#/admin
VITE_UMAMI_DASHBOARD_URL=
VITE_UMAMI_SHARE_URL=
